# Phantom Stack Environment Variables
# Copy to .env and fill in the values

# Sandboxed.sh Auth
# Use a long string that will act as both admin password and API token
RELAY_JWT=your_super_secret_jwt_here

# Slack Integration
# Required for phantom-relay
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Evolution Worker
# Repository where Sandboxed Library (rules, skills, etc) is hosted
LIBRARY_REPO_URL=https://github.com/gilby125/phantom-library.git
# Required for LLM critique
# Optional: only needed if EVOLUTION_USE_LLM_JUDGES=1
ANTHROPIC_API_KEY=sk-ant-...
EVOLUTION_USE_LLM_JUDGES=0

# Infrastructure (Defaults usually work inside Docker)
SANDBOXED_URL=http://sandboxed:3000
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434

# memory-mcp (optional)
MEMORY_MCP_HTTP_PORT=3333
