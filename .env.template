# Phantom Stack Environment Variables
# Copy to .env and fill in any empty values.

# sandboxed.sh auth
SANDBOXED_DASHBOARD_PASSWORD=change-me
SANDBOXED_JWT_SECRET=change-me-to-a-long-random-string
# Long-lived service token used by phantom-relay and evolution-worker.
SANDBOXED_JWT=

# Slack integration (optional)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Evolution worker library repo
# Public GitHub repo URL used by sandboxed.sh and evolution-worker.
LIBRARY_REPO_URL=https://github.com/gilby125/phantom-library.git

# Evolution judges
EVOLUTION_USE_LLM_JUDGES=0
ANTHROPIC_API_KEY=

# memory-mcp HTTP transport
MEMORY_MCP_HTTP_PORT=3333
